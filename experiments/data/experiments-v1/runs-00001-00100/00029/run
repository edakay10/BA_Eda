#! /usr/bin/env python

import logging
import os
import platform

from lab.calls.call import Call
from lab import tools

tools.configure_logging()

logging.info(f"node: {platform.node()}")

run_log = open("run.log", "wb")
run_err = open("run.err", "wb", buffering=0)  # disable buffering
redirects = {"stdout": run_log, "stderr": run_err}

# Make sure we're in the run directory.
os.chdir(os.path.dirname(os.path.abspath(__file__)))

Call(['/mnt/c/Users/eda/BA_Eda/.venv/bin/python3', '/mnt/c/Users/eda/BA_Eda/experiments/data/experiments-v1/code-8b0e847c94c2f563ed3a5d8ea6a8f91c04c9c173_bd874d5d/fast-downward.py', '--validate', '--overall-time-limit', '30m', '--overall-memory-limit', '3584M', '--search-time-limit', '5m', '--build', 'release', 'domain.pddl', 'problem.pddl', '--search', 'ehc(ff(), preferred=[ff()], lazy=false, global_closed=false, dead_end=false, preferred_op=true)'], hard_stderr_limit=10240, hard_stdout_limit=10240, memory_limit=None, name='planner', soft_stderr_limit=64, soft_stdout_limit=1024, time_limit=None, wall_time_limit=None, **redirects).wait()


for f in [run_log, run_err]:
    f.close()
    if os.path.getsize(f.name) == 0:
        os.remove(f.name)
